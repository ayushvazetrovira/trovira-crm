generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String
  role          String    @default("client") // admin, client
  companyId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company?  @relation(fields: [companyId], references: [id])
  activityLogs  ActivityLog[]
}

model Company {
  id            String    @id @default(cuid())
  name          String
  contactPerson String
  mobile        String
  email         String
  planId        String
  status        String    @default("active") // active, inactive, suspended
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  plan          Plan      @relation(fields: [planId], references: [id])
  subscriptions Subscription[]
  payments      Payment[]
  leads         Lead[]
  followups     Followup[]
  users         User[]
  tickets       SupportTicket[]
  settings      CrmSetting[]
  notes         Note[]
  tasks         CrmTask[]
  broadcasts    Broadcast[]
  automationRules AutomationRule[]
  emails        CrmEmail[]
  whatsappContacts WhatsAppContact[]
  webhooks      Webhook[]
}

model Plan {
  id            String    @id @default(cuid())
  name          String    @unique
  price         Int
  userLimit     Int
  leadLimit     Int       @default(500)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  subscriptions Subscription[]
  companies     Company[]
  payments      Payment[]
}

model Subscription {
  id            String    @id @default(cuid())
  companyId     String
  planId        String
  startDate     DateTime
  expiryDate    DateTime
  status        String    @default("active") // active, expired, suspended
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company   @relation(fields: [companyId], references: [id])
  plan          Plan      @relation(fields: [planId], references: [id])
}

model Payment {
  id            String    @id @default(cuid())
  companyId     String
  planId        String
  amount        Int
  paymentDate   DateTime  @default(now())
  method        String    @default("UPI") // UPI, Bank, Card
  status        String    @default("paid") // paid, pending, failed
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company   @relation(fields: [companyId], references: [id])
  plan          Plan      @relation(fields: [planId], references: [id])
}

model Lead {
  id            String    @id @default(cuid())
  companyId     String
  name          String
  phone         String
  email         String?
  company       String?
  source        String    @default("manual") // WhatsApp, Facebook, Instagram, Website, Referral, manual
  status        String    @default("New") // New, Contacted, Interested, Proposal Sent, Won, Lost
  followupDate  DateTime?
  notes         String?
  value         Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  companyRef    Company   @relation(fields: [companyId], references: [id])
  notesList     LeadNote[]
  stageHistory  LeadStageHistory[]
  followups     Followup[]
  companyNotes  Note[]
}

model LeadNote {
  id            String    @id @default(cuid())
  leadId        String
  content       String
  createdAt     DateTime  @default(now())

  lead          Lead      @relation(fields: [leadId], references: [id])
}

model Followup {
  id            String    @id @default(cuid())
  leadId        String
  companyId     String
  date          DateTime
  time          String?
  purpose       String
  status        String    @default("pending") // pending, completed, overdue
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  lead          Lead      @relation(fields: [leadId], references: [id])
  company       Company   @relation(fields: [companyId], references: [id])
}

model LeadStageHistory {
  id            String    @id @default(cuid())
  leadId        String
  fromStage     String?
  toStage       String
  createdAt     DateTime  @default(now())

  lead          Lead      @relation(fields: [leadId], references: [id])
}

model SupportTicket {
  id            String    @id @default(cuid())
  companyId     String
  subject       String
  issue         String
  status        String    @default("open") // open, in_progress, closed
  priority      String    @default("medium") // low, medium, high
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company   @relation(fields: [companyId], references: [id])
}

model ActivityLog {
  id            String    @id @default(cuid())
  userId        String
  companyId     String?
  action        String
  details       String?
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id])
}

model Note {
  id            String    @id @default(cuid())
  companyId     String
  title         String
  content       String
  color         String    @default("white") // white, yellow, green, blue, pink, purple
  isPinned      Boolean   @default(false)
  tags          String?
  leadId        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company   @relation(fields: [companyId], references: [id])
  lead          Lead?     @relation(fields: [leadId], references: [id])
}

model CrmTask {
  id            String    @id @default(cuid())
  companyId     String
  title         String
  description   String    @default("")
  assignedTo    String    @default("")
  dueDate       String    @default("")
  priority      String    @default("medium") // high, medium, low
  status        String    @default("pending") // pending, in-progress, completed
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company   @relation(fields: [companyId], references: [id])
}

model Broadcast {
  id            String    @id @default(cuid())
  companyId     String
  name          String
  message       String
  recipients    Int       @default(0)
  status        String    @default("draft") // draft, sent, delivered, queued, failed
  delivered      Int       @default(0)
  readCount     Int       @default(0)
  failed        Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company   @relation(fields: [companyId], references: [id])
}

model AutomationRule {
  id            String    @id @default(cuid())
  companyId     String
  name          String
  trigger       String    @default("new_lead_created")
  action        String    @default("send_whatsapp")
  description   String    @default("")
  status        String    @default("active") // active, paused
  executions    Int       @default(0)
  lastRun       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company   @relation(fields: [companyId], references: [id])
}

model CrmEmail {
  id            String    @id @default(cuid())
  companyId     String
  fromName      String    @default("")
  fromEmail     String    @default("")
  toEmail       String    @default("")
  subject       String    @default("")
  preview       String    @default("")
  body          String    @default("")
  isRead        Boolean   @default(false)
  isStarred     Boolean   @default(false)
  hasAttachment  Boolean   @default(false)
  folder        String    @default("inbox") // inbox, sent, draft, archive
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company   @relation(fields: [companyId], references: [id])
}

model WhatsAppContact {
  id            String    @id @default(cuid())
  companyId     String
  name          String
  phone         String
  lastMessage   String    @default("")
 lastTime      String    @default("")
  unread        Int       @default(0)
  isOnline      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company   @relation(fields: [companyId], references: [id])
  messages      WhatsAppMessage[]
}

model WhatsAppMessage {
  id            String    @id @default(cuid())
  contactId     String
  content       String    @default("")
  direction     String    @default("incoming") // incoming, outgoing
  isRead        Boolean   @default(false)
  createdAt     DateTime  @default(now())

  contact       WhatsAppContact @relation(fields: [contactId], references: [id])
}

model Webhook {
  id            String    @id @default(cuid())
  companyId     String
  name          String
  url           String
  events        String    @default("")
  status        String    @default("active") // active, paused
  lastTriggered  DateTime?
  successCount  Int       @default(0)
  failCount     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company   @relation(fields: [companyId], references: [id])
}

model CrmSetting {
  id            String    @id @default(cuid())
  companyId     String
  businessName  String?
  whatsappNumber String?
  logo          String?
  email         String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company   @relation(fields: [companyId], references: [id])
}
